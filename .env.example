# Copy to .env.local and fill in real values

# Password Sorah uses to log into the admin panel
ADMIN_PASSWORD=your-password-here

# GitHub Personal Access Token with repo:contents write access to made-in-heaven-mezuzahs
GITHUB_PAT=github_pat_...

# GitHub repo details (don't change these)
GITHUB_OWNER=ZachsHacks
GITHUB_REPO=made-in-heaven-mezuzahs

# Public env vars (visible in browser — safe, no secrets)
NEXT_PUBLIC_GITHUB_OWNER=ZachsHacks
NEXT_PUBLIC_GITHUB_REPO=made-in-heaven-mezuzahs

# ── Email notifications (optional) ────────────────────────────────────────
# Sign up free at resend.com → API Keys → create key
RESEND_API_KEY=re_...

# Email address to receive notifications (where to send alerts)
NOTIFICATION_EMAIL=your-email@example.com

# Sender address — use 'onboarding@resend.dev' for testing,
# or 'admin@yourdomain.com' after verifying your domain in Resend
NOTIFICATION_FROM=onboarding@resend.dev

# Vercel webhook secret — get this from Vercel project Settings → Webhooks
# after adding webhook URL: https://your-admin-url.vercel.app/api/vercel-webhook
VERCEL_WEBHOOK_SECRET=
